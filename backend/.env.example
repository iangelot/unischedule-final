# ═══════════════════════════════════════════════════════════════════════════════════
# UniSchedule Africa — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values

# ─── DATABASE ────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Options:
#   - Local: postgresql://user:password@localhost:5432/unischedule
#   - Supabase: postgresql://[USER]:[PASSWORD]@db.[REGION].supabase.co:5432/postgres
#   - Railway: postgresql://user:password@hostname.railway.app:5432/railway
#   - Render: postgresql://user:password@hostname.render.com:5432/database

DATABASE_URL=postgresql://user:password@localhost:5432/unischedule

# ─── JWT AUTHENTICATION ──────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── APPLICATION ENVIRONMENT ────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=debug

# ─── API CONFIGURATION ──────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Public API URL (for frontend to call)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── SECURITY & RATE LIMITING ───────────────────────────────────────────────────────
# Rate limiting configuration (milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── ERROR TRACKING & MONITORING ────────────────────────────────────────────────────
# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io
SENTRY_DSN=

# ─── SMS NOTIFICATIONS (Optional) ────────────────────────────────────────────────────
# Africa's Talking integration for SMS notifications
# Sign up: https://africastalking.com
# Note: Sandbox is free for testing

AFRICA_TALKING_API_KEY=
AFRICA_TALKING_USERNAME=

# ─── EMAIL NOTIFICATIONS (Optional) ──────────────────────────────────────────────────
# SendGrid for email notifications
SENDGRID_API_KEY=

# ─── DEPLOYMENT ─────────────────────────────────────────────────────────────────────
# Application version
APP_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT-SPECIFIC OVERRIDES (Production)
# ═══════════════════════════════════════════════════════════════════════════════════

# To enable production mode, set NODE_ENV=production
# This will:
#   - Disable debug logging
#   - Enable error tracking
#   - Require HTTPS for all connections
#   - Enforce stricter CORS policies
#   - Enable database connection pooling optimizations

# Example production values:
# NODE_ENV=production
# APP_ENV=production
# LOG_LEVEL=info
# CORS_ORIGIN=https://yourdomain.com
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
